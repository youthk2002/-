import { useState } from 'react';
import {
  RadarChart, Radar, PolarGrid, PolarAngleAxis,
  BarChart, Bar, XAxis, YAxis, Tooltip, Cell, ReferenceLine,
  ResponsiveContainer,
} from 'recharts';

const DIMS = [
  { key: 'objective',     label: '研究目的の明確さ', short: '目的'   },
  { key: 'design',        label: '実験設計・手法',   short: '設計'   },
  { key: 'data',          label: 'データの質・量',   short: 'データ' },
  { key: 'analysis',      label: '分析・解析',       short: '分析'   },
  { key: 'discussion',    label: '考察の深さ',       short: '考察'   },
  { key: 'visualization', label: '図表・可視化',     short: '図表'   },
  { key: 'originality',   label: '独自性・新規性',   short: '独自性' },
  { key: 'logic',         label: '論理的一貫性',     short: '論理性' },
];

const PURPLE = '#534AB7';
const TEAL   = '#1D9E75';

const SAMPLES = [
  {
    name: '田中太郎',
    text: 'BDD電極を用いた電気化学的PFAS分解の研究。電流密度最適化（20 mA/cm²）とpH調整によりHPLC分析で分解率98%を達成。副生成物としてフッ化物イオンの生成を確認し質量バランスを議論した。実験は3回反復し再現性を確認。今後は連続処理システムへの応用を検討する。',
  },
  {
    name: '佐藤花子',
    text: 'リチウムイオン電池Si系負極材料の特性評価。グラファイトへのSi添加（10wt%）でサイクル特性と体積膨張の関係を検討。初回放電容量は理論値の60%だった。SEM観察を実施したが対照実験が不足。考察は浅く今後の方針も不明確。',
  },
  {
    name: '鈴木一郎',
    text: '光触媒TiO2にZnOを添加し可視光応答性を向上。UV照射下でメチレンブルーの90%分解を確認。グラフは分解率の時間変化のみで、メカニズム考察や量子収率計算はなし。実験データの信頼区間も未記載で統計処理が不十分。',
  },
];

function calcHensachi(values) {
  const valid = values.filter((v) => !isNaN(v));
  if (valid.length < 2) return values.map(() => 50);
  const n    = valid.length;
  const mean = valid.reduce((a, b) => a + b, 0) / n;
  const sigma = Math.sqrt(valid.reduce((a, x) => a + (x - mean) ** 2, 0) / n);
  return values.map((x) => {
    if (isNaN(x)) return NaN;
    if (sigma === 0) return 50;
    return 50 + (10 * (x - mean)) / sigma;
  });
}

function Chip({ value }) {
  if (value == null || isNaN(value)) {
    return <span className="chip chip-neutral">—</span>;
  }
  const cls = value >= 60 ? 'chip-high' : value >= 40 ? 'chip-mid' : 'chip-low';
  return <span className={`chip ${cls}`}>{value.toFixed(1)}</span>;
}

function barColor(v) {
  return v >= 60 ? '#639922' : v >= 40 ? '#888780' : '#E24B4A';
}

export default function App() {
  const [entries,        setEntries]        = useState([]);
  const [phase,          setPhase]          = useState('input');
  const [name,           setName]           = useState('');
  const [text,           setText]           = useState('');
  const [images,         setImages]         = useState([]);
  const [submitting,     setSubmitting]     = useState(false);
  const [submitError,    setSubmitError]    = useState('');
  const [selectedId,     setSelectedId]     = useState(null);
  const [feedbacks,      setFeedbacks]      = useState({});
  const [feedbackLoading,setFeedbackLoading]= useState(false);
  const [sampleIndex,    setSampleIndex]    = useState(0);

  function computeData() {
    if (!entries.length) return { withHS: [], sorted: [], groupAvg: {} };

    const groupAvg = {};
    DIMS.forEach((d) => {
      const vals = entries.map((e) => e.scores[d.key] ?? 0);
      groupAvg[d.key] = vals.reduce((a, b) => a + b, 0) / vals.length;
    });

    const hsByDim = {};
    DIMS.forEach((d) => {
      const scores = entries.map((e) => e.scores[d.key] ?? NaN);
      const hs     = calcHensachi(scores);
      entries.forEach((e, i) => {
        if (!hsByDim[e.id]) hsByDim[e.id] = {};
        hsByDim[e.id][d.key] = hs[i];
      });
    });

    const withHS = entries.map((e) => {
      const hs   = hsByDim[e.id] || {};
      const vals = Object.values(hs).filter((x) => !isNaN(x));
      return {
        ...e,
        hs,
        avgHS: vals.length ? vals.reduce((a, b) => a + b, 0) / vals.length : 50,
        groupAvg,
      };
    });

    return { withHS, sorted: [...withHS].sort((a, b) => b.avgHS - a.avgHS), groupAvg };
  }

  const { withHS, sorted, groupAvg } = computeData();
  const selectedEntry = withHS.find((e) => e.id === selectedId) || null;

  async function readImageFiles(files) {
    return Promise.all(
      Array.from(files).map(
        (f) =>
          new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.onload  = (ev) =>
              resolve({ name: f.name, type: f.type, data: ev.target.result.split(',')[1], preview: ev.target.result });
            reader.onerror = reject;
            reader.readAsDataURL(f);
          })
      )
    );
  }

  async function handleSubmit() {
    if (!name.trim() || !text.trim()) {
      setSubmitError('名前と研究内容を入力してください');
      return;
    }
    setSubmitting(true);
    setSubmitError('');

    try {
      const content = [];
      images.forEach((img) =>
        content.push({ type: 'image', source: { type: 'base64', media_type: img.type, data: img.data } })
      );
      content.push({
        type: 'text',
        text:
          `研究者: ${name.trim()}\n研究内容:\n${text.trim()}\n\n` +
          `以下のJSON形式のみで返答（他テキスト不可）:\n` +
          `{"objective":{"score":整数0-100,"comment":"40字以内"},"design":{"score":整数,"comment":"40字以内"},` +
          `"data":{"score":整数,"comment":"40字以内"},"analysis":{"score":整数,"comment":"40字以内"},` +
          `"discussion":{"score":整数,"comment":"40字以内"},"visualization":{"score":整数,"comment":"40字以内"},` +
          `"originality":{"score":整数,"comment":"40字以内"},"logic":{"score":整数,"comment":"40字以内"}}`,
      });

      const res     = await fetch('/api/claude', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({
          model:   'claude-sonnet-4-6',
          max_tokens: 800,
          system:  '研究を評価するAIです。指定されたJSON形式のみで返答します。他のテキストは含めません。',
          messages: [{ role: 'user', content }],
        }),
      });
      const apiData = await res.json();
      const raw     = apiData.content.map((i) => i.text || '').join('');
      const parsed  = JSON.parse(raw.replace(/```json|```/g, '').trim());

      const scores   = {};
      const comments = {};
      DIMS.forEach((dim) => {
        const v          = parsed[dim.key];
        scores[dim.key]   = typeof v?.score === 'number' ? Math.min(100, Math.max(0, Math.round(v.score))) : 50;
        comments[dim.key] = v?.comment || '';
      });

      setEntries((prev) => [
        ...prev,
        { id: Date.now(), name: name.trim(), text: text.trim(), imgPreviews: images.map((i) => i.preview), scores, comments },
      ]);
      setName('');
      setText('');
      setImages([]);
    } catch (err) {
      setSubmitError('評価に失敗しました: ' + err.message);
    } finally {
      setSubmitting(false);
    }
  }

  async function selectAndFeedback(entry, force = false) {
    setSelectedId(entry.id);
    if (!force && (feedbacks[entry.id] || entries.length < 2 || feedbackLoading)) return;
    setFeedbackLoading(true);

    try {
      const e    = withHS.find((x) => x.id === entry.id);
      const rank = sorted.findIndex((x) => x.id === entry.id) + 1;
      const lines = DIMS.map(
        (d) =>
          `${d.label}: ${entry.scores[d.key]}点（平均${(groupAvg[d.key] ?? 50).toFixed(1)}点、偏差値${(e?.hs[d.key] ?? 50).toFixed(1)}）`
      ).join('\n');

      const res     = await fetch('/api/claude', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({
          model:   'claude-sonnet-4-6',
          max_tokens: 800,
          system:  '研究指導の専門家として、建設的で具体的なフィードバックを日本語で提供します。',
          messages: [{
            role:    'user',
            content: `研究者「${entry.name}」（${entries.length}名中${rank}位）へのフィードバック。\n` +
                     `研究内容:\n${entry.text}\n\n評価スコア:\n${lines}\n\n` +
                     `平均を下回る項目の改善策を中心に「■ 強み」「■ 改善ポイント」の形式で400字程度でフィードバックをください。`,
          }],
        }),
      });
      const apiData = await res.json();
      const txt     = apiData.content.map((i) => i.text || '').join('');
      setFeedbacks((prev) => ({ ...prev, [entry.id]: txt }));
    } catch (err) {
      setFeedbacks((prev) => ({ ...prev, [entry.id]: 'フィードバック生成に失敗しました: ' + err.message }));
    } finally {
      setFeedbackLoading(false);
    }
  }

  const radarData = selectedEntry
    ? DIMS.map((d) => ({
        dim:  d.short,
        自分: selectedEntry.scores[d.key] ?? 0,
        平均: parseFloat((selectedEntry.groupAvg?.[d.key] ?? 50).toFixed(1)),
      }))
    : [];

  const barData = selectedEntry
    ? DIMS.map((d) => ({
        dim:   d.short,
        偏差値: parseFloat((selectedEntry.hs?.[d.key] ?? 50).toFixed(1)),
      }))
    : [];

  if (phase === 'input') {
    return (
      <div className="container">
        <header className="header">
          <h1>研究評価・偏差値システム</h1>
          <p>研究内容とグラフ画像をAIが8項目で評価・偏差値化します</p>
        </header>

        <div className="card">
          <div className="card-header">
            <span className="card-title">研究データを登録</span>
            <button
              className="btn btn-sm"
              onClick={() => {
                setName(SAMPLES[sampleIndex].name);
                setText(SAMPLES[sampleIndex].text);
                setSampleIndex((i) => (i + 1) % SAMPLES.length);
              }}
            >
              サンプル入力
            </button>
          </div>

          <div className="form-group">
            <label>研究者名</label>
            <input
              value={name}
              onChange={(e) => setName(e.target.value)}
              placeholder="例: 田中太郎"
              className="input"
            />
          </div>

          <div className="form-group">
            <label>研究内容・説明</label>
            <textarea
              value={text}
              onChange={(e) => setText(e.target.value)}
              rows={5}
              placeholder="研究目的、手法、データ・結果、考察を記述してください"
              className="input textarea"
            />
          </div>

          <div className="form-group">
            <label>グラフ・データ画像（任意）</label>
            <div className="img-grid">
              {images.map((img, i) => (
                <div key={i} className="img-thumb">
                  <img src={img.preview} alt={img.name} />
                  <button className="img-remove" onClick={() => setImages((p) => p.filter((_, j) => j !== i))}>×</button>
                </div>
              ))}
              <button className="img-add" onClick={() => document.getElementById('img-input').click()}>
                <span>+</span>
                <small>追加</small>
              </button>
              <input
                type="file"
                id="img-input"
                accept="image/*"
                multiple
                style={{ display: 'none' }}
                onChange={async (e) => {
                  const loaded = await readImageFiles(e.target.files);
                  setImages((p) => [...p, ...loaded]);
                  e.target.value = '';
                }}
              />
            </div>
          </div>

          {submitError && <p className="error">{submitError}</p>}
          <button className="btn btn-primary" onClick={handleSubmit} disabled={submitting}>
            {submitting ? 'AI評価中…' : '評価して登録する'}
          </button>
        </div>

        {entries.length > 0 && (
          <div className="card">
            <div className="card-header">
              <span className="card-title">
                {entries.length}人が登録済み
                {entries.length < 2 && ` — あと${2 - entries.length}人で偏差値を算出`}
              </span>
              {entries.length >= 2 && (
                <button
                  className="btn btn-primary btn-sm"
                  onClick={() => { setPhase('results'); if (sorted[0]) selectAndFeedback(sorted[0]); }}
                >
                  結果を表示 →
                </button>
              )}
            </div>
            {entries.map((e) => (
              <div key={e.id} className="entry-item">
                <span className="check">✓</span>
                <span className="entry-name">{e.name}</span>
                <span className="entry-status">評価完了</span>
              </div>
            ))}
          </div>
        )}
      </div>
    );
  }

  return (
    <div className="container">
      <header className="header">
        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
          <div>
            <h1>研究評価・偏差値システム</h1>
            <p>{entries.length}名の比較結果</p>
          </div>
          <button className="btn" onClick={() => setPhase('input')}>← 追加登録</button>
        </div>
      </header>

      <div className="results-grid">
        <div>
          <p className="panel-label">偏差値ランキング（クリックで詳細）</p>
          {sorted.map((e, i) => (
            <div
              key={e.id}
              className={`person-card${selectedId === e.id ? ' selected' : ''}`}
              onClick={() => selectAndFeedback(e)}
            >
              <div className="person-header">
                <span className="rank">{i + 1}.</span>
                <span className="person-name">{e.name}</span>
                <Chip value={e.avgHS} />
              </div>
              <div className="mini-bars">
                {DIMS.map((d) => {
                  const h = e.hs[d.key] ?? 50;
                  return <div key={d.key} className="mini-bar" title={`${d.short}: ${h.toFixed(1)}`} style={{ background: barColor(h) }} />;
                })}
              </div>
            </div>
          ))}
        </div>

        <div className="detail-panel">
          {!selectedEntry ? (
            <div className="empty-state">左の人を選択してください</div>
          ) : (
            <>
              <div className="detail-header">
                <span className="detail-name">{selectedEntry.name}</span>
                <span className="detail-rank">{sorted.findIndex((e) => e.id === selectedId) + 1}位 / {entries.length}名中</span>
              </div>

              <div className="charts-grid">
                <div>
                  <p className="chart-label">スコア比較（自分 vs 平均）</p>
                  <ResponsiveContainer width="100%" height={210}>
                    <RadarChart data={radarData} margin={{ top: 10, right: 22, bottom: 10, left: 22 }}>
                      <PolarGrid stroke="var(--border-tertiary)" />
                      <PolarAngleAxis dataKey="dim" tick={{ fontSize: 11, fill: 'var(--text-secondary)' }} />
                      <Radar name="平均" dataKey="平均" stroke={TEAL}   fill={TEAL}   fillOpacity={0.15} strokeWidth={1.5} />
                      <Radar name="自分" dataKey="自分" stroke={PURPLE} fill={PURPLE} fillOpacity={0.20} strokeWidth={2}   />
                    </RadarChart>
                  </ResponsiveContainer>
                  <div className="legend">
                    <span><span style={{ color: PURPLE }}>━</span> 本人</span>
                    <span><span style={{ color: TEAL   }}>━</span> 平均</span>
                  </div>
                </div>

                <div>
                  <p className="chart-label">偏差値（項目別）</p>
                  <ResponsiveContainer width="100%" height={210}>
                    <BarChart data={barData} margin={{ top: 4, right: 4, bottom: 4, left: -25 }}>
                      <XAxis dataKey="dim" tick={{ fontSize: 9 }} />
                      <YAxis domain={['auto', 'auto']} tick={{ fontSize: 9 }} />
                      <ReferenceLine y={50} stroke="var(--border-secondary)" strokeDasharray="3 2" />
                      <Tooltip formatter={(v) => [v.toFixed(1), '偏差値']} contentStyle={{ fontSize: 11 }} />
                      <Bar dataKey="偏差値" radius={[3, 3, 0, 0]}>
                        {barData.map((d, i) => <Cell key={i} fill={barColor(d.偏差値)} />)}
                      </Bar>
                    </BarChart>
                  </ResponsiveContainer>
                </div>
              </div>

              <div className="dim-grid">
                {DIMS.map((d) => (
                  <div key={d.key} className="dim-card">
                    <div className="dim-label">{d.label}</div>
                    <div className="dim-row">
                      <span className="dim-score">{selectedEntry.scores[d.key]}点</span>
                      <Chip value={selectedEntry.hs?.[d.key] ?? 50} />
                    </div>
                    {selectedEntry.comments[d.key] && (
                      <div className="dim-comment">{selectedEntry.comments[d.key]}</div>
                    )}
                  </div>
                ))}
              </div>

              <div className="feedback-box">
                <div className="feedback-header">
                  <span>AIフィードバック</span>
                  {feedbacks[selectedId] && (
                    <button className="btn btn-sm" onClick={() => selectAndFeedback(selectedEntry, true)}>
                      {feedbackLoading ? '生成中…' : '再生成'}
                    </button>
                  )}
                </div>
                {entries.length < 2 ? (
                  <p className="muted">2人以上登録するとグループ比較フィードバックが生成されます</p>
                ) : feedbackLoading && !feedbacks[selectedId] ? (
                  <p className="muted">生成中…</p>
                ) : feedbacks[selectedId] ? (
                  <p className="feedback-text">{feedbacks[selectedId]}</p>
                ) : (
                  <button className="btn" onClick={() => selectAndFeedback(selectedEntry, true)}>
                    フィードバックを生成する
                  </button>
                )}
              </div>
            </>
          )}
        </div>
      </div>
    </div>
  );
}
